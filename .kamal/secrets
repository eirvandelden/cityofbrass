# DO NOT ENTER RAW CREDENTIALS HERE. This file is safe for git.
# Secrets are fetched from 1Password at deploy time.

SECRETS=$(kamal secrets fetch \
  --adapter 1password \
  --account vandelden.1password.com \
  --from Familie/CityOfBrass \
  KAMAL_REGISTRY_PASSWORD \
  SECRET_KEY_BASE \
  SMTP_URL \
  ACTIVEPLAY_SECRET)

KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
SECRET_KEY_BASE=$(kamal secrets extract SECRET_KEY_BASE ${SECRETS})
SMTP_URL=$(kamal secrets extract SMTP_URL ${SECRETS})
ACTIVEPLAY_SECRET=$(kamal secrets extract ACTIVEPLAY_SECRET ${SECRETS})
