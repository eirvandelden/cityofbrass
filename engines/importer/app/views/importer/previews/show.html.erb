<main>
  <h1><%= t("importer.previews.show.title") %></h1>

  <table>
    <thead>
      <tr>
        <th><%= t("importer.previews.show.file") %></th>
        <th><%= t("importer.previews.show.kind") %></th>
        <th><%= t("importer.previews.show.counts") %></th>
      </tr>
    </thead>
    <tbody>
      <% @preview.preview_files.each do |preview_file| %>
        <tr>
          <td><%= preview_file.file_file_name %></td>
          <td><%= preview_file.kind %></td>
          <td><%= preview_file.entity_counts.to_h.map { |key, value| "#{key}: #{value}" }.join(", ") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= form_with url: imports_path, method: :post do |form| %>
    <%= form.hidden_field :preview_id, value: @preview.id %>
    <%= form.submit t("importer.previews.show.confirm") %>
  <% end %>
</main>
