<div class="row">
  <div class="medium-10 medium-centered columns">
    <main>
      <h1><%= t("importer.admin.previews.show.title") %></h1>

      <table>
        <thead>
          <tr>
            <th><%= t("importer.previews.show.file") %></th>
            <th><%= t("importer.previews.show.kind") %></th>
            <th><%= t("importer.previews.show.counts") %></th>
          </tr>
        </thead>
        <tbody>
          <% @preview.preview_files.each do |preview_file| %>
            <tr>
              <td><%= preview_file.file_file_name %></td>
              <td><%= importer_kind_label(preview_file.kind) %></td>
              <td><%= importer_counts_label(preview_file.entity_counts.to_h) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= form_with url: main_app.admin_importer_imports_path, method: :post do |form| %>
        <%= form.hidden_field :preview_id, value: @preview.id %>
        <%= form.submit t("importer.admin.previews.show.confirm"), class: "button" %>
      <% end %>
    </main>
  </div>
</div>
