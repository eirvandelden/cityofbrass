<div class="row">
  <div class="medium-10 medium-centered columns">
    <main>
      <h1><%= t("importer.admin.imports.show.title") %></h1>
      <p><%= link_to t("importer.imports.show.back"), main_app.admin_importer_imports_path %></p>
      <p><%= t("importer.imports.show.status") %>: <%= importer_status_label(@import.status) %></p>

      <h2><%= t("importer.imports.show.files") %></h2>
      <table>
        <thead>
          <tr>
            <th><%= t("importer.imports.show.file") %></th>
            <th><%= t("importer.imports.show.kind") %></th>
            <th><%= t("importer.imports.show.status") %></th>
            <th><%= t("importer.imports.show.counts") %></th>
          </tr>
        </thead>
        <tbody>
          <% @import.source_file_rows.each do |file| %>
            <tr>
              <td><%= file[:name] %></td>
              <td><%= importer_kind_label(file[:kind]) %></td>
              <td><%= importer_status_label(file[:status]) %></td>
              <td><%= importer_counts_label(file[:counts]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <h2><%= t("importer.imports.show.results") %></h2>
      <table>
        <thead>
          <tr>
            <th><%= t("importer.imports.show.source_file") %></th>
            <th><%= t("importer.imports.show.object") %></th>
            <th><%= t("importer.imports.show.entity") %></th>
            <th><%= t("importer.imports.show.outcome") %></th>
            <th><%= t("importer.imports.show.reason") %></th>
          </tr>
        </thead>
        <tbody>
          <% @import.import_results.each do |result| %>
            <tr>
              <td><%= importer_result_source_file(result) %></td>
              <td><%= importer_result_object(result) %></td>
              <td><%= render "importer/imports/result_entity", result: result %></td>
              <td><%= importer_outcome_label(result.outcome) %></td>
              <td><%= importer_reason_label(result.reason) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </main>
  </div>
</div>
