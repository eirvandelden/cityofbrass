<% provide(:title, "Items | #{@item.name}") %>
<% type_array = type_split(@type) %>
<% content_for :breadcrumb do %>
  <%=  breadcrumb [
    { type_array[0] => nil },
    { type_array[1] => route_collection_path(@type.tableize) },
    { @item.name => nil }
  ] %>
<% end %>

<div class="row">
  <div class="medium-2 columns">
    <%= render :partial =>'menus/manage',
      :locals => {
        :active => 'options',
        :index_link => route_collection_path(@type.tableize),
        :view_link => route_path(@item),
        :details_link => edit_route_path(@item),
        :options_link => "#{route_path(@item)}/options"
      } %>
  </div>
  <div class="medium-10 columns">
    <%= render :partial =>'layouts/header',
      :locals => {
        :main => @item.name,
        :sub => 'Options'
      }
    %>
    <hr class="faded">
    <div class="row">
      <div class="small-12 columns">
        <div id="brass_form">
          <%= simple_form_for @item, method: :delete do |f| %>
            <%= render :partial => 'layouts/form/options', :locals => { :f => f, :record => @item } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
