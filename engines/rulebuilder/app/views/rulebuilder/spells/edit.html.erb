<% provide(:title, "Spells | #{@spell.name}") %>
<% type_array = type_split(@type) %>
<% content_for :breadcrumb do %>
  <%=  breadcrumb [
    { type_array[0] => nil },
    { type_array[1] => route_collection_path(@type.tableize) },
    { @spell.name => nil }
  ] %>
<% end %>

<div class="row">
  <div class="medium-2 columns">
    <%= render :partial =>'menus/manage',
      :locals => {
        :active => 'edit',
        :index_link => route_collection_path(@type.tableize),
        :view_link => route_path(@spell),
        :details_link => edit_route_path(@spell),
        :options_link => "#{route_path(@spell)}/options"
      } %>
  </div>
  <div class="medium-10 columns">
    <%= render :partial =>'layouts/header',
      :locals => {
        :main => @spell.name,
        :sub => 'Details',
        :add_link  => new_route_collection_path(@type.tableize.singularize),
        :can_auth => can_add(current_user, @type)
      }
    %>
    <hr class="faded">
    <div class="row">
      <div class="small-12 columns">
        <div id="brass_form">
          <%= render :partial => 'update' %>
        </div>
      </div>
    </div>
  </div>
</div>
