<% type_array = type_split(@type) %>
<% provide(:title, "#{type_array[1]} | #{@entity.name}") %>
<% content_for :breadcrumb do %>
  <%=  breadcrumb [
    { type_array[0] => nil },
    { type_array[1] => route_collection_path(@type.tableize) },
    { @entity.name => nil }
  ] %>
<% end %>

<div class="row">
  <div class="medium-3 large-2 columns">
    <%= render :partial =>'entitybuilder/menus/manage',
      :locals => {
        :index_link => route_collection_path(@type.tableize),
        :view_link => route_path(@entity),
        :about_link => edit_route_path(@entity),
        :base_link => route_path(@entity)
      } %>
  </div>
  <div class="medium-9 large-10 columns">
    <%= render :partial =>'layouts/header',
      :locals => {
        :main => @entity.name,
        :sub => 'Options'
      }
    %>
    <hr class="faded">
    <div class="row">
      <div class="medium-12 columns text-right">
        <h3 class="color-c5"><%= CoreRules.display_name(@parent_object.core_rules) %></h3>
      </div>
    </div>
    <div class="row">
      <div class="small-12 columns">
        <div id="brass_form">
          <%= form_with model: @entity, method: :delete, builder: ApplicationFormBuilder do |f| %>
            <%= render :partial => 'layouts/form/options', :locals => { :f => f, :record => @entity } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
