<% provide(:title, "Images | #{@image.name}") %>

<% content_for :breadcrumb do %>
  <%=  breadcrumb [
          { "Images" => route_collection_path(@type.tableize) },
          { @image.name => nil }
      ] %>
<% end %>

<div class="row">
  <div class="medium-12 columns">
    <%= render :partial =>'layouts/header',
      :locals => {
        :main => @image.name,
        :sub => @image.file_size,
        :icon => 'icon-images',
        :delete_link => route_target(@image),
        :delete_message => "Are you sure you want to delete \"#{@image.name}\"?",
        :can_auth => @image.can_edit?(current_user, admin_signed_in?, @type)
      }
    %>
    <hr class="faded">
    <p><i class='fa fa-angle-double-left'></i> <%= link_to "Return to Index".html_safe, route_collection_path(@type.tableize) %></p>
  </div>
</div>
<div class="row">
  <div class="medium-8 medium-centered columns">
    <%= form_with model: [@route_namespace, @image].compact, builder: ApplicationFormBuilder do |f| %>
      <%= render :partial => 'form', :locals => { :f => f } %>
    <% end %>
  </div>
</div>
