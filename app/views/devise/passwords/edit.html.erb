<div class="row">
  <div class="medium-8 medium-centered columns">
    <div class="box">
      <div class="row">
        <div class="medium-5 columns text-center">
          <%= image_tag 'logo.png', width: '200px' %>
        </div>
        <div class="medium-7 columns">
          <div class="row text-right">
            <div class="small-12 columns">
              <label class="flat">Change password</label>
            </div>
          </div>
          <%= form_with model: resource, scope: resource_name, url: password_path(resource_name), method: :put, builder: ApplicationFormBuilder do |f| %>
            <%= f.hidden_field :reset_password_token %>
            <%= f.input :password, label: 'New Password' %>
            <%= f.input :password_confirmation %>
            <%= f.button :submit, 'Confirm new password' %>
          <% end %>

        </div>
      </div>
    </div>
    <%= render 'devise/shared/poweredby' %>
  </div>
</div>
