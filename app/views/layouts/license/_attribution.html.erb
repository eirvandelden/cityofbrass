<% core_rules_name = local_assigns[:core_rules] || @entity&.core_rules %>
<% license = CoreRules.license(core_rules_name) if core_rules_name.present? %>
<% if license.present? && license["core_faq"].present? %>
  <footer class="rpg-system-attribution" aria-label="<%= t("layouts.license.attribution.aria_label") %>">
    <small><%= license["core_faq"] %></small>
  </footer>
<% end %>
